# Copy to .env and export before running market_sync.py

# Scheduler interval in minutes.
SCRAPE_INTERVAL_MINUTES=30

# Comma-separated role list. Add role+company context automatically.
TARGET_ROLES=software development engineer,backend engineer,data engineer,machine learning engineer

# Comma-separated companies to pair with each role.
TARGET_COMPANIES=amazon,microsoft,google,meta

# Search location passed to source scrapers.
TARGET_LOCATION=India

# Number of pages requested per source and query each cycle.
SCRAPE_MAX_PAGES=1

# Optional source controls (comma-separated source names)
# Supported values include: adzuna, jooble, remotive, arbeitnow, linkedin, indeed, wellfound
SOURCE_WHITELIST=
SOURCE_BLACKLIST=

# Adzuna India API credentials (required for source=adzuna)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in

# Jooble API key (required for source=jooble)
JOOBLE_API_KEY=

# Optional ML skill extraction service
ML_SERVICE_ENABLED=false
ML_SERVICE_URL=http://localhost:8100
